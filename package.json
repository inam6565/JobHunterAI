{
  "name": "jobhunterai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "cors": "2.8.5",
    "dotenv-safe": "9.1.0",
    "express": "5.1.0",
    "helmet": "8.1.0",
    "pg": "8.16.3",
    "pino": "9.7.0",
    "pino-http": "10.5.0",
    "zod": "4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "9.35.0",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.3",
    "@types/node": "24.3.1",
    "@types/pg": "8.15.5",
    "eslint": "9.35.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "16.4.0",
    "prettier": "3.6.2",
    "supertest": "7.1.4",
    "tsx": "4.20.5",
    "typescript": "5.9.2",
    "typescript-eslint": "8.43.0",
    "vitest": "4.1.4"
  }
}
